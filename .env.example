# Oracle Proxy - Environment Variables Example
# Copy this file to .env and fill in your values
# Note: .env files are gitignored for security

# =============================================================================
# Deployment Configuration
# =============================================================================

# Owner address for the contract (Neo3 address format, e.g., N...)
# Required for: deploy
N3_OWNER_ADDRESS=

# Message bridge contract address (Neo3 address format)
# Required for: deploy
N3_MESSAGE_BRIDGE=

# Native bridge contract address (Neo3 address format)
# Optional for: deploy (can be set later via setNativeBridge())
N3_NATIVE_BRIDGE=

# EVM Oracle Proxy address (20-byte 0x-prefixed hex, same as used by N3_ORACLE_PROXY_ADDRESS on EVM side)
# Optional for: deploy (can be set later via setEvmOracleProxy())
EVM_ORACLE_PROXY_ADDRESS=

# =============================================================================
# Upgrade Configuration
# =============================================================================

# Contract hash of the already-deployed contract (hex format, e.g., 0x...)
# Required for: upgrade
N3_CONTRACT_HASH=

# =============================================================================
# Wallet Configuration
# =============================================================================

# Path to the deployer wallet file (NEP-6 format)
# Required for: deploy, upgrade
WALLET_FILEPATH_DEPLOYER=

# Password for the deployer wallet (leave empty if wallet is not encrypted)
# Optional for: deploy, upgrade
WALLET_PASSWORD_DEPLOYER=

# =============================================================================
# Network Configuration
# =============================================================================

# Neo3 JSON-RPC endpoint URL
# Optional for: deploy, upgrade (defaults to http://localhost:40332)
N3_JSON_RPC=http://localhost:40332

# =============================================================================
# Output Configuration
# =============================================================================

# Path to save the contract hash after deployment
# Optional for: deploy
N3_HASH_FILE=

# =============================================================================
# Debug/Testing Configuration
# =============================================================================

# Set to "true" or "1" to prepare transaction without submitting it
# Optional for: deploy, upgrade
DRY_RUN=false
